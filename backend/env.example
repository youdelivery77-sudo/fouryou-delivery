# ════════════════════════════════════════
#  متغيرات البيئة — backend/.env
#  ⚠️ متشيلوش على GitHub أبداً
# ════════════════════════════════════════

# Firebase Service Account (JSON كامل في سطر واحد)
# تاخده من: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"delivery-office-2f6b9",...}

# البورت (اختياري — default: 3000)
PORT=3000

# رابط الفرونت (للـ CORS)
FRONTEND_URL=https://delivery-office-2f6b9.web.app
